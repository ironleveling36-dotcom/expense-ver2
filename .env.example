# ---- Telegram ----
# Get this from @BotFather on Telegram
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# ---- MongoDB (MongoDB Atlas recommended) ----
# Example Atlas URI:
# mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:pass@cluster0.mongodb.net/?retryWrites=true&w=majority
DB_NAME=expense_tracker

# ---- Admin ----
# Comma separated Telegram user IDs that get admin access.
# Find your ID with @userinfobot
ADMIN_IDS=123456789

# ---- Behaviour (optional) ----
DEFAULT_CURRENCY=₹
DEFAULT_TIMEZONE=Asia/Kolkata
MAINTENANCE_MODE=false

# ---- Rate limiting (optional) ----
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW=10

# ---- Reminder scheduler (optional) ----
REMINDER_INTERVAL=60

# ---- Logging (optional) ----
LOG_LEVEL=INFO
